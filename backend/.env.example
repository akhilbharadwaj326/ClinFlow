# ─── Database ────────────────────────────────────────────────────────────────
# Local Postgres connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/clinflow

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ─── Supabase (used in production, also needed for JWT validation) ─────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── Storage ─────────────────────────────────────────────────────────────────
# "local" for development, "supabase" for production
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./uploads

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-secret
